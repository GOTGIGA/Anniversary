# ─── แม่แบบตัวแปร Vite (ไฟล์นี้ขึ้น git ได้) ─────────────────────────────
#
# เครื่องตัวเอง:
#   npm run dev     → โหลด .env.development, .env.local, .env (ถ้ามี)
#   npm run build   → โหลด .env.production (ถ้ามี)
#   คัดลอกไฟล์นี้เป็น .env.development หรือ .env.production แล้วแก้ค่า (ทั้งคู่ถูก gitignore)
#
# GitHub Pages (CI):
#   ตั้ง Repository secrets ให้ชื่อตรงกับตัวแปรด้านล่าง (เช่น VITE_FIREBASE_API_KEY)
#   workflow จะ inject เข้า `npm run build` — ไม่ต้อง commit .env.production
#
# ─── ตัวแปร ─────────────────────────────────────────────────────────────

VITE_FIREBASE_URL=https://your-project-default-rtdb.region.firebasedatabase.app/memories.json

# RTDB base (ไม่มี path /memories) — ใช้กับ galleries / galleryPhotos
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.region.firebasedatabase.app

# Firebase Web App config (Console → Project settings → Your apps)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# optional — Firebase Analytics
# VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# อีเมล Google ที่จัดการแกลเลอรี่ได้ (คั่นด้วย comma) — ต้องตรงกับ Rules ใน Firebase
VITE_GALLERY_ADMIN_EMAILS=you@gmail.com,partner@gmail.com
